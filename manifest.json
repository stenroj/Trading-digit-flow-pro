{
  "manifest_version": 3,
  "name": "Digit Flow Pro — Rise/Fall Bot",
  "version": "1.0.0",
  "description": "Live Deriv digit analysis bot, auto trader, Matches/Differs scanner. Open in a tab from your browser toolbar.",
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://ws.derivws.com/*",
    "https://id-preview--bbce84a7-37fa-4a9b-bc83-c0c29a1f739f.lovable.app/*",
    "https://stenroj.github.io/*"
  ],
  "action": {
    "default_icon": "icon.png",
    "default_title": "Open Digit Flow Pro"
  },
  "background": {
    "service_worker": "background.js"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "icons": {
    "48": "icon.png",
    "128": "icon.png"
  }
}
